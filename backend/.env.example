# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=mf_pos_user
DB_PASSWORD=change_me
DB_NAME=marqueeflow_pos_db

# JWT (required — use a strong random string per environment)
JWT_SECRET=change_this_to_a_secure_random_string

# Server
PORT=8085
NODE_ENV=production
UPLOAD_DIR=/var/www/marqueeflow-pos-uploads

# App URLs
APP_URL=https://pos.marqueeflow.com
ADMIN_EMAIL=support@marqueeflow.com

# Email (Hostinger SMTP)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USER=support@marqueeflow.com
MAIL_PASS=your_app_password

# Redis (optional)
REDIS_URL=redis://localhost:6379
